{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "command": "node .cursor/hooks/mcp-explanation-post-tool.mjs",
        "matcher": "generate_math_explanation"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "node .cursor/hooks/auto-docs-worklog-after-response.mjs",
        "timeout": 8,
        "failClosed": false
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/auto-upload-supabase-after-edit.mjs",
        "timeout": 10,
        "failClosed": false
      }
    ]
  }
}
