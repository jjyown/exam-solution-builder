# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local runtime data (not for repo)
시험지/
작업 완료/
*.pdf
*.docx
*.txt

# local helper scripts (not needed for hosting)
*.bat
*.sh

# docker files (optional; keep only if Railway deploys via Docker)
Dockerfile
.dockerignore
docker-compose.yml

# internal notes
AGENTS.md
CLAUDE.md
# typescript
*.tsbuildinfo
next-env.d.ts
