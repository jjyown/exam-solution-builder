# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local runtime data (not for repo)
시험지/
크롭된 시험지/
해설지 최종본/
# textbook OCR 로컬 미러 — Drive 에 정본 저장됨 (CLI/UI 모두 자동 미러).
# 책별 수백 .md 파일이 누적돼 git 노이즈만 키움 (예: 9권 = 수천 파일).
교재 참고자료/
*.pdf
*.docx
*.txt
# 참고 족보를 `참고용 문제/`에 두고 깃허브에 같이 올릴 때만 아래 예외로 추적(.txt/.pdf 전역 무시 해제)
!참고용 문제/
!참고용 문제/**/*.txt
!참고용 문제/**/*.pdf

# local helper scripts (not needed for hosting)
*.bat
*.sh

# Mathpix OCR 캐시(로컬)
/.cache/

# scratch / 로컬만 쓰는 작업 폴더
/work/
# 디버그 dump (DEBUG_VISION_RAW_DUMP=true 시 raw OCR 응답 저장)
/tmp/
# 교재 OCR·분할 실험 산출(대용량) — README만 추적
/scratch/ocr-mapping-runs/*
!/scratch/ocr-mapping-runs/README.md

# typescript
*.tsbuildinfo
next-env.d.ts

# Cursor legacy archive (not needed in deploy artifacts)
/_archive/
